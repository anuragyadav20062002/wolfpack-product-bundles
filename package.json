{
  "name": "wolfpack-product-bundles",
  "private": true,
  "scripts": {
    "build": "remix vite:build",
    "build:widgets": "node scripts/build-widget-bundles.js all && node scripts/minify-assets.js js",
    "build:widgets:full-page": "node scripts/build-widget-bundles.js full-page && node scripts/minify-assets.js js",
    "build:widgets:product-page": "node scripts/build-widget-bundles.js product-page && node scripts/minify-assets.js js",
    "build:sdk": "node scripts/build-widget-bundles.js sdk && node scripts/minify-assets.js js",
    "minify:assets": "node scripts/minify-assets.js",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "deploy:prod": "cd extensions/bundle-cart-transform-rs && rustup run stable cargo build --target=wasm32-unknown-unknown --release && cd ../.. && shopify app deploy --config shopify.app.toml",
    "deploy:sit": "cd extensions/bundle-cart-transform-rs && rustup run stable cargo build --target=wasm32-unknown-unknown --release && cd ../.. && shopify app deploy --config shopify.app.wolfpack-product-bundles-sit.toml",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "remix-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm run start",
    "setup": "prisma generate && prisma migrate deploy",
    "setup:reset": "prisma migrate reset --force --skip-seed && prisma generate",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "migrate:dev": "prisma migrate dev",
    "push:db": "prisma db push",
    "generate:prisma": "prisma generate",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "webhook-worker": "tsx scripts/webhook-worker.ts",
    "bulk-sync": "tsx scripts/bulk-sync-bundles.ts",
    "test": "ts-node tests/test-runner.ts",
    "test:unit": "ts-node tests/test-runner.ts unit",
    "test:integration": "ts-node tests/test-runner.ts integration",
    "test:e2e": "ts-node tests/test-runner.ts e2e",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --collectCoverageFrom='app/**/*.{ts,tsx}' --collectCoverageFrom='extensions/**/*.{ts,tsx}'",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "pre-deploy": "npm test && npm run build"
  },
  "type": "module",
  "engines": {
    "node": "^18.20 || ^20.10 || >=21.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.10.1",
    "@prisma/client": "^6.14.0",
    "@remix-run/dev": "^2.16.1",
    "@remix-run/fs-routes": "^2.16.1",
    "@remix-run/node": "^2.16.1",
    "@remix-run/react": "^2.16.1",
    "@remix-run/serve": "^2.16.1",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^12.0.0",
    "@shopify/polaris-icons": "^8.11.1",
    "@shopify/shopify-app-remix": "^3.7.0",
    "@shopify/shopify-app-session-storage-prisma": "^6.0.0",
    "@tailwindcss/postcss": "^4.1.12",
    "autoprefixer": "^10.4.21",
    "crisp-sdk-web": "^1.0.25",
    "dotenv": "^17.2.1",
    "graphql-request": "^7.2.0",
    "inngest": "^3.52.6",
    "isbot": "^5.1.0",
    "pg": "^8.16.2",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.0",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.19.2",
    "vite-tsconfig-paths": "^5.0.1"
  },
  "devDependencies": {
    "@preact/signals": "^2.3.0",
    "@remix-run/eslint-config": "^2.16.1",
    "@remix-run/route-config": "^2.16.1",
    "@shopify/api-codegen-preset": "^0.0.4",
    "@shopify/ui-extensions": "2025.10.0",
    "@types/eslint": "^9.6.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.2.0",
    "@types/react": "^18.2.31",
    "@types/react-dom": "^18.2.14",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "chrome-devtools-mcp": "^0.20.3",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-prisma": "^1.0.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-unicorn": "^51.0.1",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "preact": "^10.10.0",
    "prettier": "^3.2.4",
    "prisma": "^6.13.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.2.2",
    "vite": "^6.2.2"
  },
  "workspaces": [
    "extensions/*"
  ],
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "resolutions": {
    "@graphql-tools/url-loader": "8.0.16",
    "@graphql-codegen/client-preset": "4.7.0",
    "@graphql-codegen/typescript-operations": "4.5.0",
    "minimatch": "9.0.9",
    "tar": "7.5.11",
    "undici": "6.23.0",
    "valibot": "1.2.0",
    "rollup": "4.59.0",
    "esbuild": "0.25.0"
  },
  "overrides": {
    "@graphql-tools/url-loader": "8.0.16",
    "@graphql-codegen/client-preset": "4.7.0",
    "@graphql-codegen/typescript-operations": "4.5.0",
    "minimatch": "9.0.9",
    "tar": "7.5.11",
    "undici": "6.23.0",
    "valibot": "1.2.0",
    "rollup": "4.59.0",
    "esbuild": "0.25.0"
  },
  "author": "Anurag"
}
