{% comment %}
  Bundle Property Hider (App Embed)

  Hides underscore-prefixed line item properties from the cart page/drawer.
  By Shopify convention, properties starting with _ should be hidden,
  but some themes don't implement this. This embed ensures they're always hidden.

  Issue: hide-bundle-cart-properties-1
{% endcomment %}

<script>
(function() {
  'use strict';

  var UNDERSCORE_PREFIX = '_';

  function hideUnderscoreProperties() {
    // Strategy 1: Find all elements whose text content is an underscore-prefixed property name
    // These appear as key-value pairs in cart line items across different theme structures
    var allElements = document.querySelectorAll(
      '[data-cart-item-property], .product-option, .cart-item__property, ' +
      '.cart__meta-item, .cart-item-property, .order-summary__property, ' +
      'dt, li, span, p, td, div'
    );

    for (var i = 0; i < allElements.length; i++) {
      var el = allElements[i];
      // Skip if already hidden or if it has many children (container element)
      if (el.style.display === 'none' || el.children.length > 3) continue;

      var text = el.textContent.trim();

      // Check if this element's direct text starts with _ (property name)
      // Match patterns like "_bundle_name:" or "_bundle_name: value" or just "_bundle_name"
      if (text.length > 1 && text.charAt(0) === UNDERSCORE_PREFIX && /^_[a-z_]+/i.test(text)) {
        // Check it's a leaf-ish element (not a large container)
        var innerText = el.innerText || el.textContent;
        if (innerText.length < 500) {
          hidePropertyElement(el);
        }
      }
    }
  }

  function hidePropertyElement(el) {
    // Hide the element itself
    el.style.display = 'none';

    // Some themes use dt/dd pairs — hide the sibling dd too
    if (el.tagName === 'DT' && el.nextElementSibling && el.nextElementSibling.tagName === 'DD') {
      el.nextElementSibling.style.display = 'none';
    }

    // Some themes wrap key + value in a parent container — check if hiding all
    // underscore children means the parent is now empty
    var parent = el.parentElement;
    if (parent) {
      var visibleChildren = 0;
      for (var j = 0; j < parent.children.length; j++) {
        if (parent.children[j].style.display !== 'none') {
          visibleChildren++;
        }
      }
      if (visibleChildren === 0) {
        parent.style.display = 'none';
      }
    }
  }

  // Run on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', hideUnderscoreProperties);
  } else {
    hideUnderscoreProperties();
  }

  // MutationObserver for dynamic cart drawers and AJAX carts
  var debounceTimer;
  var observer = new MutationObserver(function() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(hideUnderscoreProperties, 200);
  });

  observer.observe(document.body, { childList: true, subtree: true });
})();
</script>
