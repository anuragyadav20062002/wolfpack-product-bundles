{% schema %}
{
  "name": "t:bundle_full_page.name",
  "target": "section",
  "enabled_on": {
    "templates": ["page"]
  },
  "stylesheet": "bundle-widget-full-page.css",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:bundle_full_page.settings.paragraph_content"
    },
    {
      "type": "text",
      "id": "bundle_id",
      "label": "t:bundle_full_page.settings.bundle_id_label",
      "info": "t:bundle_full_page.settings.bundle_id_info"
    },
    {
      "type": "text",
      "id": "app_url",
      "label": "t:bundle_full_page.settings.app_url_label",
      "info": "t:bundle_full_page.settings.app_url_info"
    },
    {
      "type": "header",
      "content": "t:bundle_full_page.settings.content_customization_header"
    },
    {
      "type": "text",
      "id": "custom_title",
      "label": "t:bundle_full_page.settings.custom_title_label",
      "info": "t:bundle_full_page.settings.custom_title_info"
    },
    {
      "type": "textarea",
      "id": "custom_description",
      "label": "t:bundle_full_page.settings.custom_description_label",
      "info": "t:bundle_full_page.settings.custom_description_info"
    },
    {
      "type": "header",
      "content": "t:bundle_full_page.settings.display_header"
    },
    {
      "type": "checkbox",
      "id": "show_bundle_title",
      "label": "t:bundle_full_page.settings.show_bundle_title_label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_bundle_description",
      "label": "t:bundle_full_page.settings.show_bundle_description_label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_step_timeline",
      "label": "t:bundle_full_page.settings.show_step_timeline_label",
      "info": "t:bundle_full_page.settings.show_step_timeline_info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_category_tabs",
      "label": "t:bundle_full_page.settings.show_category_tabs_label",
      "info": "t:bundle_full_page.settings.show_category_tabs_info",
      "default": true
    },
    {
      "type": "header",
      "content": "Card Layout Settings"
    },
    {
      "type": "range",
      "id": "product_card_spacing",
      "label": "Product card spacing",
      "info": "Space between product cards (in pixels)",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "product_cards_per_row",
      "label": "Cards per row (desktop)",
      "info": "Number of product cards to display in each row on desktop screens",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Promo Banner Settings"
    },
    {
      "type": "checkbox",
      "id": "show_promo_banner",
      "label": "Show promo banner",
      "default": true
    },
    {
      "type": "text",
      "id": "promo_banner_subtitle",
      "label": "Banner subtitle",
      "info": "Text shown above bundle name (e.g., 'Mix & Match')",
      "default": "Mix & Match"
    },
    {
      "type": "text",
      "id": "promo_banner_tagline",
      "label": "Banner tagline (no discount)",
      "info": "Tagline shown when no discount is configured",
      "default": "Create Your Perfect Bundle"
    },
    {
      "type": "text",
      "id": "promo_banner_note",
      "label": "Banner note (no discount)",
      "info": "Note text shown when no discount is configured",
      "default": "Mix & Match Your Favorites"
    }
  ]
}
{% endschema %}

{% comment %}
  Full-Page Bundle Widget
  For standalone bundle pages (not product pages)
  Merchants create a page and assign this template

  AUTOMATED WORKFLOW:
  1. Bundle ID is automatically set via page metafield when using "Place Widget Now"
  2. Falls back to manual block setting for backwards compatibility
{% endcomment %}

{% comment %}
  Resolve bundle ID from three sources in priority order:

  1. page.handle  — MOST RELIABLE (primary source).
                    App creates bundle pages with handle "bundle-{bundleId}".
                    Bundle IDs are Prisma CUIDs (lowercase alphanumeric, no special
                    chars), so `remove_first: 'bundle-'` gives back the exact bundleId.
                    Zero dependency on metafields, definitions, or deploy state.

  2. page.metafields['$app'].bundle_id  — NOTE: '$app' in the Admin API expands to
                    'app--{app_id}' internally. The correct Liquid accessor would be
                    page.metafields['app--{app_id}']['bundle_id'] but the app_id is not
                    easily available at Liquid render time. This path is kept as a
                    secondary fallback but may always return nil. Source 1 supersedes it.

  3. block.settings.bundle_id  — Manual fallback. Merchant enters bundle ID in the
                    Shopify theme editor. Per Shopify docs, ALL theme app extension
                    blocks (including target="section") access settings via block.settings,
                    not section.settings.
{% endcomment %}

{% comment %} Source 1: Extract bundle ID from page handle (primary — always works) {% endcomment %}
{% if page.handle contains 'bundle-' %}
  {% assign bundle_id_from_handle = page.handle | remove_first: 'bundle-' %}
{% else %}
  {% assign bundle_id_from_handle = nil %}
{% endif %}

{% comment %} Source 2: Page metafield (may not resolve due to $app namespace expansion) {% endcomment %}
{% assign app_namespace = '$app' %}
{% assign bundle_id_from_metafield = page.metafields[app_namespace].bundle_id %}

{% comment %} Source 3: Block setting (manual theme editor input) {% endcomment %}
{% assign bundle_id_from_setting = block.settings.bundle_id %}

{% comment %} Priority: handle > metafield > block setting {% endcomment %}
{% if bundle_id_from_handle and bundle_id_from_handle != blank %}
  {% assign bundle_id = bundle_id_from_handle %}
  {% assign bundle_id_source = "page_handle" %}
{% elsif bundle_id_from_metafield and bundle_id_from_metafield != blank %}
  {% assign bundle_id = bundle_id_from_metafield %}
  {% assign bundle_id_source = "page_metafield_automated" %}
{% elsif bundle_id_from_setting and bundle_id_from_setting != blank %}
  {% assign bundle_id = bundle_id_from_setting %}
  {% assign bundle_id_source = "block_setting_manual" %}
{% else %}
  {% assign bundle_id = nil %}
  {% assign bundle_id_source = "none" %}
{% endif %}

{% assign should_show_widget = false %}

{% comment %} Check if bundle ID is provided from any source {% endcomment %}
{% if bundle_id and bundle_id != blank %}
  {% assign should_show_widget = true %}
{% endif %}

{% comment %} THEME EDITOR: Allow preview even without bundle ID {% endcomment %}
{% if request.design_mode %}
  {% assign should_show_widget = true %}
  {% unless bundle_id and bundle_id != blank %}
    {% assign bundle_id = "preview" %}
  {% endunless %}
{% endif %}

{% if should_show_widget %}
  <div
    {{ block.shopify_attributes }}
    id="bundle-builder-app"
    data-bundle-id="{{ bundle_id }}"
    data-bundle-type="full_page"
    data-app-url="{{ block.settings.app_url | default: '' }}"
    data-show-title="{{ block.settings.show_bundle_title }}"
    data-show-description="{{ block.settings.show_bundle_description }}"
    data-show-step-timeline="{{ block.settings.show_step_timeline }}"
    data-show-category-tabs="{{ block.settings.show_category_tabs }}"
    data-custom-title="{{ block.settings.custom_title | escape }}"
    data-custom-description="{{ block.settings.custom_description | escape }}"
    data-product-card-spacing="{{ block.settings.product_card_spacing }}"
    data-product-cards-per-row="{{ block.settings.product_cards_per_row }}"
    data-show-promo-banner="{{ block.settings.show_promo_banner | default: true }}"
    data-promo-banner-subtitle="{{ block.settings.promo_banner_subtitle | default: 'Mix & Match' | escape }}"
    data-promo-banner-tagline="{{ block.settings.promo_banner_tagline | default: 'Create Your Perfect Bundle' | escape }}"
    data-promo-banner-note="{{ block.settings.promo_banner_note | default: 'Mix & Match Your Favorites' | escape }}"
    class="bundle-widget-container bundle-widget-full-page"
  >
    <div class="bundle-loading">
      <div class="loading-spinner"></div>
    </div>
  </div>

  <script>
    console.log('🎯 [FULL_PAGE_BUNDLE] Widget Loading:', {
      bundleId: {{ bundle_id | json }},
      bundleIdSource: {{ bundle_id_source | json }},
      bundleType: 'full_page',
      pageHandle: {{ page.handle | json }},
      pageTitle: {{ page.title | json }},
      isThemeEditor: (window.Shopify && window.Shopify.designMode) || false,
      automated: {{ bundle_id_source | json }} === 'page_metafield_automated'
    });

    // Initialize Shopify context for full-page bundles
    if (!window.bundleWidgetContext) {
      window.shopCurrency = {{ shop.currency | json }};
      window.shopMoneyFormat = {{ shop.money_format | json }};
      window.shopifyMultiCurrency = {
        shopBaseCurrency: {{ shop.currency | json }},
        shopMoneyFormat: {{ shop.money_format | json }},
        customerCurrency: null,
        customerMoneyFormat: null,
        exchangeRate: 1,
        isMultiCurrencyEnabled: false
      };
      window.bundleWidgetContext = true;
    }
  </script>

  <!-- Inject app URL from shop metafield -->
  <script>
    {% assign app_namespace = '$app' %}
    {% assign shop_app_metafields = shop.metafields[app_namespace] %}
    {% assign server_url_field = nil %}
    {% if shop_app_metafields %}
      {% assign server_url_field = shop_app_metafields['serverUrl'] %}
    {% endif %}
    window.__BUNDLE_APP_URL__ = {% if server_url_field %}{{ server_url_field.value | json }}{% else %}null{% endif %};
  </script>

  <!-- Load Design Control Panel Settings (Dynamic CSS from Database) -->
  <!-- This injects CSS variables from DesignSettings table for full_page bundle type -->
  <!-- CRITICAL: Without this, DCP settings won't apply to full-page bundles! -->
  <!-- NOTE: Using app proxy URL instead of asset_url because design settings are dynamically -->
  <!-- generated from database, not static theme assets. This is intentional. -->
  {% # theme-check-disable RemoteAsset %}
  <link
    rel="stylesheet"
    href="{{ shop.url }}/apps/product-bundles/api/design-settings/{{ shop.domain }}?bundleType=full_page"
    type="text/css"
  >
  {% # theme-check-enable RemoteAsset %}

  <!-- Load widget JavaScript (modal component is bundled inside) -->
  <script src="{{ 'bundle-widget-full-page-bundled.js' | asset_url }}" defer></script>
{% else %}
  <div class="bundle-widget-placeholder" style="padding: 40px; text-align: center; background: #f0f3eb; border-radius: 8px;">
    <h3 style="margin: 0 0 10px;">Full-Page Bundle Widget</h3>
    <p style="margin: 0; color: #666;">Please configure a Bundle ID in the block settings to display the bundle builder.</p>
  </div>
{% endif %}
