{% schema %}
{
  "name": "Wolfpack - Product Page",
  "target": "section",
  "enabled_on": {
    "templates": ["product"],
    "groups": ["*"]
  },
  "stylesheet": "bundle-widget.css",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "t:bundle_product_page.settings.enabled_label",
      "info": "t:bundle_product_page.settings.enabled_info",
      "default": true
    },
    {
      "type": "text",
      "id": "bundle_id",
      "label": "t:bundle_product_page.settings.bundle_id_label",
      "info": "t:bundle_product_page.settings.bundle_id_info"
    },
    {
      "type": "text",
      "id": "app_url",
      "label": "t:bundle_product_page.settings.app_url_label",
      "info": "t:bundle_product_page.settings.app_url_info"
    },
    {
      "type": "header",
      "content": "t:bundle_product_page.settings.layout_sizing_header"
    },
    {
      "type": "range",
      "id": "widget_max_width",
      "min": 300,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "t:bundle_product_page.settings.widget_max_width_label",
      "default": 800,
      "info": "t:bundle_product_page.settings.widget_max_width_info"
    },
    {
      "type": "range",
      "id": "step_box_size",
      "min": 100,
      "max": 250,
      "step": 10,
      "unit": "px",
      "label": "t:bundle_product_page.settings.step_box_size_label",
      "default": 150,
      "info": "t:bundle_product_page.settings.step_box_size_info"
    },
    {
      "type": "range",
      "id": "step_cards_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "t:bundle_product_page.settings.step_cards_per_row_label",
      "default": 3,
      "info": "t:bundle_product_page.settings.step_cards_per_row_info"
    },
    {
      "type": "range",
      "id": "button_height",
      "min": 40,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "t:bundle_product_page.settings.button_height_label",
      "default": 55,
      "info": "t:bundle_product_page.settings.button_height_info"
    },
    {
      "type": "header",
      "content": "t:bundle_product_page.settings.display_options_header"
    },
    {
      "type": "checkbox",
      "id": "show_bundle_title",
      "label": "t:bundle_product_page.settings.show_bundle_title_label",
      "info": "t:bundle_product_page.settings.show_bundle_title_info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_step_numbers",
      "label": "t:bundle_product_page.settings.show_step_numbers_label",
      "info": "t:bundle_product_page.settings.show_step_numbers_info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_footer_messaging",
      "label": "t:bundle_product_page.settings.show_footer_messaging_label",
      "info": "t:bundle_product_page.settings.show_footer_messaging_info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:bundle_product_page.settings.progress_bar_styling_header"
    },
    {
      "type": "color",
      "id": "success_color",
      "label": "t:bundle_product_page.settings.success_color_label",
      "info": "t:bundle_product_page.settings.success_color_info",
      "default": "#28a745"
    },
    {
      "type": "range",
      "id": "progress_bar_height",
      "min": 6,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "t:bundle_product_page.settings.progress_bar_height_label",
      "default": 12,
      "info": "t:bundle_product_page.settings.progress_bar_height_info"
    },
    {
      "type": "range",
      "id": "progress_bar_border_radius",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "t:bundle_product_page.settings.progress_bar_border_radius_label",
      "default": 50,
      "info": "t:bundle_product_page.settings.progress_bar_border_radius_info"
    },
    {
      "type": "header",
      "content": "t:bundle_product_page.settings.spacing_layout_header"
    },
    {
      "type": "range",
      "id": "container_spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "t:bundle_product_page.settings.container_spacing_label",
      "default": 20,
      "info": "t:bundle_product_page.settings.container_spacing_info"
    },
    {
      "type": "range",
      "id": "element_spacing",
      "min": 0,
      "max": 30,
      "step": 5,
      "unit": "px",
      "label": "t:bundle_product_page.settings.element_spacing_label",
      "default": 15,
      "info": "t:bundle_product_page.settings.element_spacing_info"
    },
    {
      "type": "range",
      "id": "step_card_gap",
      "min": 0,
      "max": 30,
      "step": 5,
      "unit": "px",
      "label": "t:bundle_product_page.settings.step_card_gap_label",
      "default": 15,
      "info": "t:bundle_product_page.settings.step_card_gap_info"
    },
    {
      "type": "range",
      "id": "modal_header_padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "t:bundle_product_page.settings.modal_header_padding_label",
      "default": 40,
      "info": "t:bundle_product_page.settings.modal_header_padding_info"
    },
    {
      "type": "range",
      "id": "modal_body_padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "t:bundle_product_page.settings.modal_body_padding_label",
      "default": 40,
      "info": "t:bundle_product_page.settings.modal_body_padding_info"
    },
    {
      "type": "header",
      "content": "t:bundle_product_page.settings.step_navigation_styling_header"
    },
    {
      "type": "range",
      "id": "step_tab_border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "t:bundle_product_page.settings.step_tab_border_radius_label",
      "default": 10,
      "info": "t:bundle_product_page.settings.step_tab_border_radius_info"
    },
    {
      "type": "header",
      "content": "t:bundle_product_page.settings.modal_ui_customization_header"
    },
    {
      "type": "range",
      "id": "modal_product_card_height",
      "min": 140,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "t:bundle_product_page.settings.modal_product_card_height_label",
      "default": 160,
      "info": "t:bundle_product_page.settings.modal_product_card_height_info"
    },
    {
      "type": "range",
      "id": "modal_product_image_height",
      "min": 50,
      "max": 90,
      "step": 5,
      "unit": "px",
      "label": "t:bundle_product_page.settings.modal_product_image_height_label",
      "default": 70,
      "info": "t:bundle_product_page.settings.modal_product_image_height_info"
    },
    {
      "type": "color",
      "id": "modal_product_price_color",
      "label": "t:bundle_product_page.settings.modal_product_price_color_label",
      "info": "t:bundle_product_page.settings.modal_product_price_color_info",
      "default": "#2c5530"
    },
    {
      "type": "color",
      "id": "modal_product_price_bg",
      "label": "t:bundle_product_page.settings.modal_product_price_bg_label",
      "info": "t:bundle_product_page.settings.modal_product_price_bg_info",
      "default": "#f0f8f0"
    },
    {
      "type": "range",
      "id": "modal_product_title_size",
      "min": 70,
      "max": 120,
      "step": 5,
      "unit": "%",
      "label": "t:bundle_product_page.settings.modal_product_title_size_label",
      "default": 90,
      "info": "t:bundle_product_page.settings.modal_product_title_size_info"
    },
    {
      "type": "range",
      "id": "modal_product_price_size",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "t:bundle_product_page.settings.modal_product_price_size_label",
      "default": 85,
      "info": "t:bundle_product_page.settings.modal_product_price_size_info"
    }
  ]
}
{% endschema %}
{% comment %}
  Bundle Widget - Shopify Standard Architecture (Approach 1: Hybrid)
  Reads bundle configuration from variant-level metafields.
  See: https://shopify.dev/docs/apps/build/product-merchandising/bundles/create-bundle-app
{% endcomment %}

{% assign is_bundle_product = false %}
{% assign bundle_ui_config = nil %}
{% assign bundle_id = nil %}
{% assign should_show_widget = false %}
{% assign hide_default_buttons = false %}

{% comment %}
  Use $app reserved namespace for app-owned metafields
  This matches the namespace: "$app" used when setting metafields via GraphQL
  Reference: https://shopify.dev/docs/apps/build/custom-data/metafields/manage-metafields
{% endcomment %}
{% assign app_namespace = '$app' %}

{% comment %}
  SHOPIFY STANDARD: Bundle metafields are stored on ProductVariant (not Product)
  Access the first variant where bundle configuration is stored
  Reference: https://shopify.dev/docs/api/liquid/objects/product#product-variants
{% endcomment %}
{% assign bundle_variant = product.variants.first %}

{% if bundle_variant %}
  {% comment %} Access variant metafields per Shopify Liquid documentation {% endcomment %}
  {% assign variant_metafields = bundle_variant.metafields[app_namespace] %}

  {% if variant_metafields %}
    {% comment %} Check for bundle_ui_config metafield (Approach 1: Hybrid) {% endcomment %}
    {% assign bundle_ui_config_field = variant_metafields['bundle_ui_config'] %}

    {% if bundle_ui_config_field and bundle_ui_config_field.value %}
      {% comment %} Parse JSON metafield value {% endcomment %}
      {% assign bundle_ui_config = bundle_ui_config_field.value %}
      {% assign is_bundle_product = true %}
      {% assign should_show_widget = true %}
      {% assign hide_default_buttons = true %}

      {% comment %} Extract bundle ID from UI config {% endcomment %}
      {% if bundle_ui_config.bundleId %}
        {% assign bundle_id = bundle_ui_config.bundleId %}
      {% endif %}
    {% endif %}
  {% endif %}
{% endif %}

{% comment %} THEME EDITOR: Allow manual bundle ID override for preview {% endcomment %}
{% if request.design_mode and block.settings.bundle_id and block.settings.bundle_id != blank %}
  {% assign should_show_widget = true %}
  {% assign bundle_id = block.settings.bundle_id %}
{% endif %}

{% if should_show_widget %}
    <div
      {{ block.shopify_attributes }}
      id="bundle-builder-app"
      data-bundle-id="{{ bundle_id }}"
      data-app-url="{{ block.settings.app_url | default: '' }}"
      data-is-bundle-product="{{ is_bundle_product }}"
      data-is-container-product="{{ is_bundle_product }}"
      data-container-bundle-id="{{ bundle_id }}"
      data-bundle-config='{{ bundle_ui_config | json }}'
      data-hide-default-buttons="{{ hide_default_buttons }}"
      data-show-title="{{ block.settings.show_bundle_title }}"
      data-show-step-numbers="{{ block.settings.show_step_numbers }}"
      data-show-footer-messaging="{{ block.settings.show_footer_messaging }}"
      style="
        --step-box-size: {{ block.settings.step_box_size }}px;
        --button-height: {{ block.settings.button_height }}px;
        --widget-max-width: {{ block.settings.widget_max_width }}px;
        --step-cards-per-row: {{ block.settings.step_cards_per_row }};
        --container-spacing: {{ block.settings.container_spacing | default: 20 }}px;
        --element-spacing: {{ block.settings.element_spacing | default: 15 }}px;
        --step-card-spacing: {{ block.settings.step_card_gap | default: 15 }}px;
        --modal-header-padding: {{ block.settings.modal_header_padding | default: 40 }}px;
        --modal-body-padding: {{ block.settings.modal_body_padding | default: 40 }}px;
        --button-spacing: 25px;
        --modal-footer-bg-color: #ffffff;
        --modal-footer-text-color: #2d3748;
        --modal-footer-success-color: {{ block.settings.success_color }};
        --footer-bg-color: #f8f9fa;
        --footer-text-color: {{ block.settings.success_color }};
        --progress-bar-height: {{ block.settings.progress_bar_height | default: 12 }}px;
        --progress-bar-border-radius: {{ block.settings.progress_bar_border_radius | default: 999 }}px;
        --savings-badge-color: {{ block.settings.success_color }};
        --modal-tab-border-radius: {{ block.settings.step_tab_border_radius }}px;
        --modal-product-card-height: {{ block.settings.modal_product_card_height }}px;
        --modal-product-image-height: {{ block.settings.modal_product_image_height }}px;
        --modal-product-price-color: {{ block.settings.modal_product_price_color }};
        --modal-product-price-bg: {{ block.settings.modal_product_price_bg }};
        --modal-product-title-size: {{ block.settings.modal_product_title_size }}%;
        --modal-product-price-size: {{ block.settings.modal_product_price_size }}%;
      "
      class="bundle-widget-container"
    >
      {% if block.settings.show_bundle_title %}
        <div class="bundle-header">
          <h2 class="bundle-title"></h2>
        </div>
      {% endif %}

      <div class="bundle-steps">
        <!-- Dynamic steps will be rendered here by JavaScript -->
      </div>

      <div class="bundle-includes">
        <!-- Dynamic included products will be rendered here by JavaScript -->
      </div>

      <button class="add-bundle-to-cart">Add Bundle to Cart</button>

      <!-- Footer discount messaging with progress bar -->
      {% if block.settings.show_footer_messaging %}
      <div class="bundle-footer-messaging" style="display: none;">
        <div class="footer-discount-text"></div>
        <div class="footer-progress-container">
          <div class="progress-bar">
            <div class="progress-fill"></div>
          </div>
          <div class="progress-details">
            <span class="progress-text">
              <span class="current-quantity">0</span> / <span class="target-quantity">0</span>
            </span>
          </div>
        </div>
      </div>
      {% endif %}
    </div>

    <!-- 🔧 [THEME_DEBUG] Bundle Widget Debugging Information -->
    <script>
      console.log('🎯 [THEME_DEBUG] Bundle Widget Loading (Shopify Standard):', {
        enabled: {{ block.settings.enabled | json }},
        bundleId: {{ bundle_id | json }},
        productId: {{ product.id | json }},
        productHandle: {{ product.handle | json }},
        productTemplate: {{ product.template_suffix | json }},
        isBundleProduct: {{ is_bundle_product | json }},
        shouldShowWidget: {{ should_show_widget | json }},
        hideDefaultButtons: {{ hide_default_buttons | json }},
        isThemeEditor: (window.Shopify && window.Shopify.designMode) || false,
        urlParams: new URLSearchParams(window.location.search).toString()
      });

      // 🔍 Variant metafield debugging (Shopify Standard Architecture)
      console.log('🔍 [THEME_DEBUG] Variant Metafields:', {
        bundleUiConfig: {{ bundle_ui_config | json }},
        variantId: {{ bundle_variant.id | json }},
        appNamespace: {{ app_namespace | json }}
      });
    </script>

    {% comment %} Hide default buy buttons if this is a container product {% endcomment %}
    {% if hide_default_buttons %}
    <style>
      /* Hide default Shopify buy buttons on container products */
      .product-form__cart-submit,
      .product-form__buttons button[name="add"],
      .btn.product-form__cart-submit,
      button[name="add"]:not(.bundle-add-to-cart),
      input[name="add"]:not(.bundle-add-to-cart),
      form[action*="/cart/add"] button[type="submit"]:not(.bundle-add-to-cart),
      form[action*="/cart/add"] input[type="submit"]:not(.bundle-add-to-cart),
      .shopify-payment-button,
      .dynamic-checkout__content,
      .additional-checkout-buttons,
      .payment-button-container,
      [data-testid="AddToCartButton"]:not(.bundle-add-to-cart),
      .add-to-cart-button:not(.bundle-add-to-cart),
      .btn-addtocart:not(.bundle-add-to-cart),
      .product-add-to-cart:not(.bundle-add-to-cart) {
        display: none !important;
      }

      /* Show bundle widget prominently */
      #bundle-builder-app {
        background: #f8f9fa;
        border: 2px solid #007ace;
        border-radius: 12px;
        padding: 24px;
        margin: 20px 0;
        box-shadow: 0 4px 12px rgba(0, 122, 206, 0.1);
      }
    </style>
    {% endif %}
{% endif %}

<script>
  // Inject app URL from shop metafield (auto-synced when merchant accesses app admin)
  // Note: Changed from appconfig namespace to $app namespace per TOML definition
  // single_line_text_field metafields require .value accessor per Shopify docs
  {% assign shop_app_metafields = shop.metafields[app_namespace] %}
  {% assign server_url_field = nil %}
  {% if shop_app_metafields %}
    {% assign server_url_field = shop_app_metafields['serverUrl'] %}
  {% endif %}
  window.__BUNDLE_APP_URL__ = {% if server_url_field %}{{ server_url_field.value | json }}{% else %}null{% endif %};
</script>

<script>
  // Initialize global Shopify context for widget
  // Widget reads bundle data directly from data-bundle-config attribute (no window global needed)
  if (!window.bundleWidgetContext) {
    window.currentProductId = {{ product.id | json }};
    window.currentProductHandle = {{ product.handle | json }};
    window.currentProductCollections = {{ product.collections | json }};
    window.shopCurrency = {{ shop.currency | json }};
    window.shopMoneyFormat = {{ shop.money_format | json }};

    // Enhanced multi-currency support
    window.shopifyMultiCurrency = {
      shopBaseCurrency: {{ shop.currency | json }},
      shopMoneyFormat: {{ shop.money_format | json }},
      customerCurrency: null, // Will be detected dynamically
      customerMoneyFormat: null,
      exchangeRate: 1,
      isMultiCurrencyEnabled: false
    };
    window.bundleWidgetInstanceCount = (window.bundleWidgetInstanceCount || 0) + 1;
    window.bundleWidgetContext = true;

    // Enhanced debugging for bundle data loading
    const productBundleConfig = {{ bundle_ui_config | json }};
    console.log('🎯 [BUNDLE_DATA] Product ID:', {{ product.id | json }});
    console.log('🎯 [BUNDLE_DATA] Product Handle:', {{ product.handle | json }});
    console.log('🎯 [BUNDLE_DATA] Has bundle config metafield:', !!productBundleConfig);
    console.log('🎯 [BUNDLE_DATA] Bundle config value:', productBundleConfig);
    console.log('🎯 [BUNDLE_DATA] App namespace:', {{ app_namespace | json }});
    console.log('🎯 [BUNDLE_DATA] First variant ID:', {{ bundle_variant.id | json }});
    console.log('🎯 [BUNDLE_DATA] Is bundle product flag:', {{ is_bundle_product | json }});
    console.log('🎯 [BUNDLE_DATA] Should show widget:', {{ should_show_widget | json }});

    // Debug app namespace metafields (checking specific keys only - cannot serialize entire metafields collection)
    {% if bundle_variant %}
      console.log('🔍 [METAFIELD_DEBUG] Checking variant metafields in namespace:', {{ app_namespace | json }});

      {% comment %}Check each expected metafield individually{% endcomment %}
      {% assign bundle_ui_config_check = bundle_variant.metafields[app_namespace]['bundle_ui_config'] %}
      {% assign component_reference_check = bundle_variant.metafields[app_namespace]['component_reference'] %}

      console.log('🔍 [METAFIELD_DEBUG] bundle_ui_config exists:', {{ bundle_ui_config_check | json }} !== null);
      console.log('🔍 [METAFIELD_DEBUG] component_reference exists:', {{ component_reference_check | json }} !== null);

      {% if bundle_ui_config_check == null and component_reference_check == null %}
        console.log('⚠️ [METAFIELD_DEBUG] No bundle metafields found in namespace:', {{ app_namespace | json }});
        console.log('⚠️ [METAFIELD_DEBUG] This means either:');
        console.log('   1. Metafield definitions not created (need fresh install after latest deploy)');
        console.log('   2. Metafield values not set on this variant');
        console.log('   3. Wrong namespace being used');
      {% endif %}
    {% endif %}

    if (productBundleConfig && productBundleConfig.bundleId) {
      console.log('✅ [BUNDLE_DATA] Container product detected:', productBundleConfig.name);
      console.log('✅ [BUNDLE_DATA] Bundle ID:', productBundleConfig.bundleId);
    } else {
      console.log('ℹ️ [BUNDLE_DATA] Not a bundle container product - no bundle_ui_config metafield found');
    }
  }
  
  // Auto-extract bundle ID from URL for seamless widget placement
  function extractBundleIdFromUrl() {
    const urlParams = new URLSearchParams(window.location.search);
    const bundleIdFromUrl = urlParams.get('bundleId');

    // Enhanced theme editor detection
    const isInThemeEditor = window.location.pathname.includes('/editor') ||
                           window.location.search.includes('preview_theme_id') ||
                           window.location.search.includes('previewPath') ||
                           window.location.search.includes('addAppBlockId') ||
                           document.referrer.includes('admin.shopify.com') ||
                           window.parent !== window || // In iframe
                           window.top !== window;      // In iframe

    if (bundleIdFromUrl && isInThemeEditor) {
      // Store for the widget to use
      window.autoDetectedBundleId = bundleIdFromUrl;
      window.isThemeEditorContext = true; // Flag for widget to use

      console.log('[BUNDLE_WIDGET] Auto-detected bundle ID from theme editor:', bundleIdFromUrl);

      // Try multiple approaches to auto-populate the bundle_id setting in theme editor
      const autoPopulateBundleId = () => {
        // Try various selectors for the bundle_id input field
        const selectors = [
          'input[name*="bundle_id"]',
          'input[id*="bundle_id"]',
          '[data-setting-key="bundle_id"] input',
          '.setting[data-setting-key="bundle_id"] input',
          'input[data-name="bundle_id"]'
        ];

        for (const selector of selectors) {
          const bundleIdInput = document.querySelector(selector);
          if (bundleIdInput && !bundleIdInput.value) {
            bundleIdInput.value = bundleIdFromUrl;
            // Trigger change event to ensure the setting is saved
            bundleIdInput.dispatchEvent(new Event('change', { bubbles: true }));
            bundleIdInput.dispatchEvent(new Event('input', { bubbles: true }));
            console.log('[BUNDLE_WIDGET] Auto-populated bundle ID in theme editor settings');
            return true;
          }
        }
        return false;
      };

      // Try immediately and also with delays for different theme editor loading patterns
      autoPopulateBundleId();
      setTimeout(autoPopulateBundleId, 500);
      setTimeout(autoPopulateBundleId, 1500);
      setTimeout(autoPopulateBundleId, 3000);

      // Also update any existing widget instances with the bundle ID
      const existingWidgets = document.querySelectorAll('#bundle-builder-app');
      existingWidgets.forEach(widget => {
        if (!widget.dataset.bundleId || widget.dataset.bundleId === '') {
          widget.dataset.bundleId = bundleIdFromUrl;
          console.log('[BUNDLE_WIDGET] Updated existing widget with bundle ID:', bundleIdFromUrl);

          // Mark for theme editor preview mode
          widget.setAttribute('data-theme-editor-preview', 'true');

          // Trigger widget re-initialization if it already tried to load
          if (window.__bundleWidgetLoaded || window.__bundleWidgetLoading) {
            console.log('[BUNDLE_WIDGET] Triggering widget re-initialization with bundleId');
            window.dispatchEvent(new CustomEvent('bundleWidgetReload'));
          }
        }
      });

    } else if (isInThemeEditor) {
      // Even without bundleId, mark as theme editor context
      window.isThemeEditorContext = true;
      console.log('[BUNDLE_WIDGET] Theme editor context detected without bundle ID');
    }
  }
  
  // Run on page load
  extractBundleIdFromUrl();
</script>

<!-- Modal will be dynamically created by JavaScript to prevent duplicates -->

<link rel="stylesheet" href="{{ 'bundle-widget.css' | asset_url }}">

<!-- Load Design Control Panel Settings (Dynamic CSS from Database) -->
<!-- This injects CSS variables from DesignSettings table for product_page bundle type -->
<!-- NOTE: Using app proxy URL instead of asset_url because design settings are dynamically -->
<!-- generated from database, not static theme assets. This is intentional. -->
{% # theme-check-disable RemoteAsset %}
<link
  rel="stylesheet"
  href="{{ shop.url }}/apps/product-bundles/api/design-settings/{{ shop.domain }}?bundleType=product_page&v={{ 'now' | date: '%s' }}"
  type="text/css"
>
{% # theme-check-enable RemoteAsset %}

<!-- Load widget JavaScript dynamically to bypass 10KB Shopify limit -->
<script>
