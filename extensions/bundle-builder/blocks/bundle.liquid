{% schema %}
{
  "name": "Bundle Builder",
  "target": "section",
  "enabled_on": {
    "templates": ["product"],
    "groups": ["*"]
  },
  "stylesheet": "bundle-widget.css",
  "javascript": "bundle-widget.js",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Show bundle widget",
      "info": "Display the product bundle widget on this page",
      "default": true
    },
    {
      "type": "text",
      "id": "bundle_id",
      "label": "Bundle configuration ID",
      "info": "Enter the specific bundle ID to display. This is automatically populated when adding the widget from the bundle admin, or you can manually enter a bundle ID here."
    },
    {
      "type": "header",
      "content": "Layout and sizing"
    },
    {
      "type": "range",
      "id": "widget_max_width",
      "min": 300,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Widget maximum width",
      "default": 800,
      "info": "Sets the maximum width of the entire bundle widget container on larger screens"
    },
    {
      "type": "range",
      "id": "step_box_size",
      "min": 100,
      "max": 250,
      "step": 10,
      "unit": "px",
      "label": "Product step card size",
      "default": 150,
      "info": "Controls the width and height of individual product selection step cards"
    },
    {
      "type": "range",
      "id": "step_cards_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Step cards per row",
      "default": 3,
      "info": "Number of product step cards to display per row on larger screens"
    },
    {
      "type": "range",
      "id": "button_height",
      "min": 40,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Add to cart button height",
      "default": 55,
      "info": "Controls the height of the main add to cart button"
    },
    {
      "type": "header",
      "content": "Spacing controls"
    },
    {
      "type": "range",
      "id": "container_spacing",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Container spacing",
      "default": 20,
      "info": "Overall spacing around the widget container (margin and padding)"
    },
    {
      "type": "range",
      "id": "element_spacing",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Element spacing",
      "default": 15,
      "info": "Spacing between and within widget elements (margins and padding)"
    },
    {
      "type": "range",
      "id": "step_card_spacing",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Step card spacing",
      "default": 15,
      "info": "Space around and within individual step cards"
    },
    {
      "type": "range",
      "id": "button_spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Button spacing",
      "default": 25,
      "info": "Margin and padding around the add to cart button"
    },
    {
      "type": "header",
      "content": "Display options"
    },
    {
      "type": "checkbox",
      "id": "show_bundle_title",
      "label": "Display bundle title",
      "info": "Shows the bundle name at the top of the widget",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_step_numbers",
      "label": "Display step numbers",
      "info": "Shows numbered indicators on each bundle step card",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_footer_messaging",
      "label": "Display discount progress messaging",
      "info": "Shows progress indicators and discount messages to encourage bundle completion",
      "default": true
    },
    {
      "type": "header",
      "content": "Discount messaging"
    },
    {
      "type": "textarea",
      "id": "discount_text_template",
      "label": "Progress encouragement message",
      "default": "Add {discountConditionDiff} {discountUnit} to get the bundle at {discountValueUnit}{discountValue}",
      "info": "Text shown to encourage customers to complete their bundle. Available variables: {discountConditionDiff}, {discountUnit}, {discountValue}, {discountValueUnit}"
    },
    {
      "type": "textarea",
      "id": "success_message_template", 
      "label": "Bundle completion message",
      "default": "Congratulations 🎉 you have gotten the best offer on your bundle!",
      "info": "Celebratory message displayed when the customer has qualified for the bundle discount"
    },
    {
      "type": "text",
      "id": "progress_text_template",
      "label": "Progress counter format",
      "default": "{selectedQuantity} / {targetQuantity} items",
      "info": "Format for the progress counter display. Available variables: {selectedQuantity}, {targetQuantity}"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "footer_background_color",
      "label": "Message background color",
      "info": "Background color for the discount messaging area",
      "default": "#f8f9fa"
    },
    {
      "type": "color",
      "id": "footer_text_color",
      "label": "Message text color",
      "info": "Text color for discount messages and progress indicators",
      "default": "#2e7d32"
    },
    {
      "type": "color",
      "id": "progress_bar_color",
      "label": "Progress bar color",
      "info": "Color of the progress bar as it fills up",
      "default": "#28a745"
    },
    {
      "type": "color",
      "id": "savings_badge_color",
      "label": "Savings highlight color",
      "info": "Color for the savings amount badge and highlights",
      "default": "#28a745"
    }
  ]
}
{% endschema %}
{% comment %} Bundle Container Product Detection - ENHANCED LOGIC {% endcomment %}
{% assign is_container_product = false %}
{% assign container_bundle_id = null %}
{% assign bundle_config = null %}
{% assign auto_display_mode = false %}

{% comment %} PRIMARY CHECK: Is this product a designated bundle container? {% endcomment %}
{% if product.metafields['$app:bundle_isolation'].bundle_product_type == 'cart_transform_bundle' %}
  {% assign is_container_product = true %}
  {% assign container_bundle_id = product.metafields['$app:bundle_isolation'].owns_bundle_id %}
  {% assign auto_display_mode = true %}
  {% comment %} Load bundle configuration from container metafields {% endcomment %}
  {% if product.metafields.bundle_discounts.cart_transform_config %}
    {% assign bundle_config = product.metafields.bundle_discounts.cart_transform_config %}
  {% endif %}
{% endif %}

{% comment %} SECONDARY CHECK: Widget configured with specific bundle ID (theme editor) {% endcomment %}
{% assign widget_has_bundle_id = false %}
{% if block.settings.bundle_id and block.settings.bundle_id != blank %}
  {% assign widget_has_bundle_id = true %}
{% endif %}

{% comment %} WIDGET DISPLAY LOGIC - STRICT CONTAINER MATCHING {% endcomment %}
{% assign should_show_widget = false %}

{% comment %} 1. CONTAINER PRODUCT: Always show if this is a bundle container {% endcomment %}
{% if is_container_product %}
  {% assign should_show_widget = true %}
  {% assign show_bundle_widget = true %}
  {% comment %} Hide default buy buttons automatically {% endcomment %}
  {% assign hide_default_buttons = true %}
{% comment %} 2. THEME EDITOR: Show if bundle ID is manually configured {% endcomment %}
{% elsif widget_has_bundle_id and block.settings.enabled %}
  {% assign should_show_widget = true %}
  {% assign show_bundle_widget = true %}
{% comment %} 3. ALL OTHER CASES: Don't show to avoid confusion {% endcomment %}
{% else %}
  {% assign should_show_widget = false %}
  {% endif %}

{% if should_show_widget %}
    <!-- 🔧 [THEME_DEBUG] Bundle Widget Debugging Information -->
    <script>
      console.log('🎯 [THEME_DEBUG] Bundle Container Widget Loading:', {
        enabled: {{ block.settings.enabled | json }},
        bundleId: {{ block.settings.bundle_id | json }},
        productId: {{ product.id | json }},
        productHandle: {{ product.handle | json }},
        isContainerProduct: {{ is_container_product | json }},
        containerBundleId: {{ container_bundle_id | json }},
        widgetHasBundleId: {{ widget_has_bundle_id | json }},
        shouldShowWidget: {{ should_show_widget | json }},
        hideDefaultButtons: {{ hide_default_buttons | json }},
        autoDisplayMode: {{ auto_display_mode | json }},
        isThemeEditor: (window.Shopify && window.Shopify.designMode) || false,
        urlParams: new URLSearchParams(window.location.search).toString()
      });
    </script>

    {% comment %} Hide default buy buttons if this is a container product {% endcomment %}
    {% if hide_default_buttons %}
    <style>
      /* Hide default Shopify buy buttons on container products */
      .product-form__cart-submit,
      .product-form__buttons button[name="add"],
      .btn.product-form__cart-submit,
      button[name="add"]:not(.bundle-add-to-cart),
      input[name="add"]:not(.bundle-add-to-cart),
      form[action*="/cart/add"] button[type="submit"]:not(.bundle-add-to-cart),
      form[action*="/cart/add"] input[type="submit"]:not(.bundle-add-to-cart),
      .shopify-payment-button,
      .dynamic-checkout__content,
      .additional-checkout-buttons,
      .payment-button-container,
      [data-testid="AddToCartButton"]:not(.bundle-add-to-cart),
      .add-to-cart-button:not(.bundle-add-to-cart),
      .btn-addtocart:not(.bundle-add-to-cart),
      .product-add-to-cart:not(.bundle-add-to-cart) {
        display: none !important;
      }

      /* Show bundle widget prominently */
      #bundle-builder-app {
        background: #f8f9fa;
        border: 2px solid #007ace;
        border-radius: 12px;
        padding: 24px;
        margin: 20px 0;
        box-shadow: 0 4px 12px rgba(0, 122, 206, 0.1);
      }

      /* Add bundle indicator to product title */
      .product__title:before,
      .product-title:before,
      h1:before {
        content: "🎁 Bundle: ";
        color: #007ace;
        font-weight: bold;
      }
    </style>
    {% endif %}

    <div
      id="bundle-builder-app"
      data-bundle-id="{% if is_container_product and container_bundle_id %}{{ container_bundle_id }}{% else %}{{ block.settings.bundle_id }}{% endif %}"
      data-is-container-product="{{ is_container_product }}"
      data-container-bundle-id="{{ container_bundle_id }}"
      data-auto-display-mode="{{ auto_display_mode }}"
      data-bundle-config="{{ bundle_config | escape }}"
      data-hide-default-buttons="{{ hide_default_buttons }}"
      data-show-title="{{ block.settings.show_bundle_title }}"
      data-show-step-numbers="{{ block.settings.show_step_numbers }}"
      data-show-footer-messaging="{{ block.settings.show_footer_messaging }}"
      data-discount-text-template="{{ block.settings.discount_text_template | escape }}"
      data-success-message-template="{{ block.settings.success_message_template | escape }}"
      data-progress-text-template="{{ block.settings.progress_text_template | escape }}"
      style="
        --step-box-size: {{ block.settings.step_box_size }}px;
        --button-height: {{ block.settings.button_height }}px;
        --widget-max-width: {{ block.settings.widget_max_width }}px;
        --step-cards-per-row: {{ block.settings.step_cards_per_row }};
        --container-spacing: {{ block.settings.container_spacing }}px;
        --element-spacing: {{ block.settings.element_spacing }}px;
        --step-card-spacing: {{ block.settings.step_card_spacing }}px;
        --button-spacing: {{ block.settings.button_spacing }}px;
        --footer-bg-color: {{ block.settings.footer_background_color }};
        --footer-text-color: {{ block.settings.footer_text_color }};
        --progress-bar-color: {{ block.settings.progress_bar_color }};
        --savings-badge-color: {{ block.settings.savings_badge_color }};
      "
      class="bundle-widget-container"
    >
      {% if block.settings.show_bundle_title %}
        <div class="bundle-header">
          <h2 class="bundle-title"></h2>
        </div>
      {% endif %}

      <div class="bundle-steps">
        <!-- Dynamic steps will be rendered here by JavaScript -->
      </div>

      <div class="bundle-includes">
        <!-- Dynamic included products will be rendered here by JavaScript -->
      </div>

      <button class="add-bundle-to-cart">Add Bundle to Cart</button>

      <!-- Footer discount messaging with progress bar -->
      <div class="bundle-footer-messaging" style="display: none;">
        <div class="footer-progress-container">
          <div class="progress-bar-wrapper">
            <div class="progress-bar">
              <div class="progress-fill"></div>
            </div>
            <div class="progress-text">
              <span class="current-quantity">0</span> / <span class="target-quantity">0</span> items
            </div>
          </div>
          <div class="footer-discount-text"></div>
          <div class="footer-savings-display" style="display: none;">
            <span class="savings-badge">You save: <span class="savings-amount"></span></span>
          </div>
        </div>
      </div>
    </div>
{% endif %}

<script>
  // Enhanced bundle data loading with multiple fallback sources
  if (!window.allBundlesData) {
    // Primary source: shop metafield (custom namespace)
    const primaryBundleData = {{ shop.metafields.custom.all_bundles.value | json }};

    // Fallback source: app namespace metafield
    const fallbackBundleData = {{ shop.metafields['$app:all_bundles'].value | json }};

    // Alternative app namespace
    const altAppBundleData = {{ shop.metafields.app.all_bundles.value | json }};

    // Use the first available data source
    window.allBundlesData = primaryBundleData || fallbackBundleData || altAppBundleData || {};

    window.currentProductId = {{ product.id | json }};
    window.currentProductHandle = {{ product.handle | json }};
    window.currentProductCollections = {{ product.collections | json }};
    window.shopCurrency = {{ shop.currency | json }};
    window.shopMoneyFormat = {{ shop.money_format | json }};
    window.bundleWidgetInstanceCount = (window.bundleWidgetInstanceCount || 0) + 1;

    // Enhanced debugging for bundle data loading
    console.log('🎯 [BUNDLE_DATA] Loading bundle data for product:', {{ product.id | json }});
    console.log('🎯 [BUNDLE_DATA] Primary bundle data (custom namespace):', !!primaryBundleData, primaryBundleData ? Object.keys(primaryBundleData).length : 0);
    console.log('🎯 [BUNDLE_DATA] Fallback bundle data ($app namespace):', !!fallbackBundleData, fallbackBundleData ? Object.keys(fallbackBundleData).length : 0);
    console.log('🎯 [BUNDLE_DATA] Alt app bundle data (app namespace):', !!altAppBundleData, altAppBundleData ? Object.keys(altAppBundleData).length : 0);
    console.log('🎯 [BUNDLE_DATA] Final bundle data:', !!window.allBundlesData, window.allBundlesData ? Object.keys(window.allBundlesData).length : 0);

    // If no bundle data is available, try to fetch it dynamically
    if (!window.allBundlesData || Object.keys(window.allBundlesData).length === 0) {
      console.log('🔄 [BUNDLE_DATA] No bundle data found in metafields, attempting dynamic fetch...');

      // Try to fetch bundle data from a custom endpoint if available
      fetch('/apps/bundle-discounts/api/bundles.json', {
        method: 'GET',
        headers: {
          'Content-Type': 'application/json',
        }
      })
      .then(response => {
        if (response.ok) {
          return response.json();
        }
        throw new Error('Bundle data fetch failed');
      })
      .then(data => {
        console.log('✅ [BUNDLE_DATA] Successfully fetched bundle data dynamically:', data);
        window.allBundlesData = data.bundles || data || {};
        // Re-initialize widgets with new data
        if (window.reinitializeAllBundleWidgets) {
          setTimeout(() => window.reinitializeAllBundleWidgets(), 100);
        }
      })
      .catch(error => {
        console.log('⚠️ [BUNDLE_DATA] Dynamic fetch failed, using empty bundle data:', error);
        window.allBundlesData = {};
      });
    }
  }
  
  // Auto-extract bundle ID from URL for seamless widget placement
  function extractBundleIdFromUrl() {
    const urlParams = new URLSearchParams(window.location.search);
    const bundleIdFromUrl = urlParams.get('bundleId');

    // Enhanced theme editor detection
    const isInThemeEditor = window.location.pathname.includes('/editor') ||
                           window.location.search.includes('preview_theme_id') ||
                           window.location.search.includes('previewPath') ||
                           window.location.search.includes('addAppBlockId') ||
                           document.referrer.includes('admin.shopify.com') ||
                           window.parent !== window || // In iframe
                           window.top !== window;      // In iframe

    if (bundleIdFromUrl && isInThemeEditor) {
      // Store for the widget to use
      window.autoDetectedBundleId = bundleIdFromUrl;
      window.isThemeEditorContext = true; // Flag for widget to use

      console.log('[BUNDLE_WIDGET] Auto-detected bundle ID from theme editor:', bundleIdFromUrl);

      // Try multiple approaches to auto-populate the bundle_id setting in theme editor
      const autoPopulateBundleId = () => {
        // Try various selectors for the bundle_id input field
        const selectors = [
          'input[name*="bundle_id"]',
          'input[id*="bundle_id"]',
          '[data-setting-key="bundle_id"] input',
          '.setting[data-setting-key="bundle_id"] input',
          'input[data-name="bundle_id"]'
        ];

        for (const selector of selectors) {
          const bundleIdInput = document.querySelector(selector);
          if (bundleIdInput && !bundleIdInput.value) {
            bundleIdInput.value = bundleIdFromUrl;
            // Trigger change event to ensure the setting is saved
            bundleIdInput.dispatchEvent(new Event('change', { bubbles: true }));
            bundleIdInput.dispatchEvent(new Event('input', { bubbles: true }));
            console.log('[BUNDLE_WIDGET] Auto-populated bundle ID in theme editor settings');
            return true;
          }
        }
        return false;
      };

      // Try immediately and also with delays for different theme editor loading patterns
      autoPopulateBundleId();
      setTimeout(autoPopulateBundleId, 500);
      setTimeout(autoPopulateBundleId, 1500);
      setTimeout(autoPopulateBundleId, 3000);

      // Also update any existing widget instances with the bundle ID
      const existingWidgets = document.querySelectorAll('#bundle-builder-app');
      existingWidgets.forEach(widget => {
        if (!widget.dataset.bundleId) {
          widget.dataset.bundleId = bundleIdFromUrl;
          console.log('[BUNDLE_WIDGET] Updated existing widget with bundle ID');
        }
      });

    } else if (isInThemeEditor) {
      // Even without bundleId, mark as theme editor context
      window.isThemeEditorContext = true;
      console.log('[BUNDLE_WIDGET] Theme editor context detected without bundle ID');
    }
  }
  
  // Run on page load
  extractBundleIdFromUrl();
</script>

<!-- Modal will be dynamically created by JavaScript to prevent duplicates -->

<link rel="stylesheet" href="{{ 'bundle-widget.css' | asset_url }}">
<script src="{{ 'bundle-widget.js' | asset_url }}" defer></script>

{% comment %} Auto-injection for bundle products that don't have manual widget placement {% endcomment %}
{% unless should_show_widget %}
<script>
// 🎯 Auto-inject bundle widget on bundle products when widget isn't manually added
(function() {
  'use strict';

  // Check if we're on a product page
  if (!window.location.pathname.includes('/products/')) return;

  // Check if bundle widget already exists
  if (document.getElementById('bundle-builder-app')) return;

  // Check if this is a bundle product via tags
  const productData = {{ product | json }};
  if (!productData || !productData.tags) return;

  const tags = Array.isArray(productData.tags) ? productData.tags : productData.tags.split(',').map(t => t.trim());
  const isBundleProduct = tags.includes('bundle') || tags.includes('cart-transform');

  if (!isBundleProduct) return;

  console.log('🎯 [AUTO_INJECT] Bundle product detected, injecting widget');

  // Hide default buttons first
  const buttonSelectors = [
    'button[name="add"]', 'input[name="add"]', 'form[action*="/cart/add"] button[type="submit"]',
    '.btn.product-form__cart-submit', '.shopify-payment-button', '[data-testid="AddToCartButton"]'
  ];

  buttonSelectors.forEach(selector => {
    document.querySelectorAll(selector).forEach(btn => {
      if (btn && !btn.getAttribute('data-bundle-hidden')) {
        btn.style.display = 'none';
        btn.setAttribute('data-bundle-hidden', 'true');
      }
    });
  });

  // Find injection point
  const injectionTarget = document.querySelector('.product-form') ||
                         document.querySelector('.product__form') ||
                         document.querySelector('form[action*="/cart/add"]') ||
                         document.body;

  // Create bundle widget
  const widgetHTML = `
    <div id="bundle-builder-app" data-bundle-id="" data-is-bundle-product="true"
         data-auto-display-mode="true" style="margin: 20px 0; padding: 20px; border: 2px solid #28a745; border-radius: 8px; background: #f8f9fa;">
      <h2 style="color: #28a745; margin-bottom: 15px;">🎯 Bundle Product Detected</h2>
      <p>Loading bundle configuration...</p>
      <button style="background: #28a745; color: white; padding: 12px 24px; border: none; border-radius: 4px; font-size: 16px; cursor: pointer;">
        Add Bundle to Cart
      </button>
    </div>`;

  injectionTarget.insertAdjacentHTML('beforeend', widgetHTML);
  console.log('🎯 [AUTO_INJECT] Bundle widget injected successfully');
})();
</script>
{% endunless %} 