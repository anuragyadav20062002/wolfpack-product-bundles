{% comment %}
  Wolfpack Full-Page Bundle — App Embed Block
  ============================================
  Activated once per store in Theme Settings > App Embeds.
  Renders the bundle widget automatically on any page that has the
  custom.bundle_id metafield set by the app (written when "Place Widget Now" is clicked).
  No per-page block placement required.
{% endcomment %}

{% assign bundle_id = page.metafields.custom.bundle_id %}

{% comment %} Skip render on non-bundle pages (no metafield) except in theme editor preview {% endcomment %}
{% unless bundle_id != blank or request.design_mode %}
  {% break %}
{% endunless %}

{% unless bundle_id != blank %}
  {% assign bundle_id = 'preview' %}
{% endunless %}

{% comment %} Bundle config metafield — written by app on sync, enables zero-proxy first paint {% endcomment %}
{% assign bundle_config_metafield = page.metafields.custom.bundle_config %}
{% if bundle_config_metafield.value != blank %}
  {% assign bundle_config_json = bundle_config_metafield.value | json %}
{% else %}
  {% assign bundle_config_json = 'null' %}
{% endif %}

<div
  id="bundle-builder-app"
  data-bundle-id="{{ bundle_id }}"
  data-bundle-type="full_page"
  data-bundle-config="{{ bundle_config_json | escape }}"
  data-show-title="true"
  data-show-description="true"
  data-show-category-tabs="true"
  data-product-card-spacing="20"
  data-product-cards-per-row="4"
  data-show-promo-banner="true"
  data-promo-banner-subtitle="Mix &amp; Match"
  data-promo-banner-tagline="Create Your Perfect Bundle"
  data-promo-banner-note="Mix &amp; Match Your Favorites"
  class="bundle-widget-container bundle-widget-full-page"
>
  <div class="bundle-loading">
    <div class="loading-spinner"></div>
  </div>
</div>

<style>
  /* Hide the theme's page <h1> on bundle pages — the widget renders its own title */
  .section-content-wrapper h1,
  .page__heading h1,
  .page-title h1,
  h1.page-title,
  .page-header h1,
  .main-page-title { display: none !important; }
  /* Hide the section wrapper padding that creates a blank gray gap above the widget */
  .shopify-section:has(.main-page-title) { display: none !important; }
</style>

<script>
  // The body embed injects after the footer — move it inside <main> so it renders in the correct position.
  // This runs synchronously before DOMContentLoaded to avoid a flash of misplaced content.
  (function () {
    function relocateWidget() {
      var block = document.getElementById('shopify-block-{{ block.id }}') ||
                  document.querySelector('.shopify-block.shopify-app-block:has(#bundle-builder-app)');
      var main  = document.getElementById('MainContent');
      if (!block || !main) return;
      // Already inside main — nothing to do
      if (main.contains(block)) return;
      main.insertBefore(block, main.firstChild);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', relocateWidget);
    } else {
      relocateWidget();
    }
  })();
</script>

<script>
  if (!window.bundleWidgetContext) {
    window.shopCurrency = {{ shop.currency | json }};
    window.shopMoneyFormat = {{ shop.money_format | json }};
    window.shopifyMultiCurrency = {
      shopBaseCurrency: {{ shop.currency | json }},
      shopMoneyFormat: {{ shop.money_format | json }},
      customerCurrency: {{ cart.currency.iso_code | json }},
      customerMoneyFormat: {{ shop.money_format | json }},
      isMultiCurrencyEnabled: {% if shop.enabled_currencies.size > 1 %}true{% else %}false{% endif %}
    };
    window.bundleWidgetContext = true;
  }
</script>

<script>
  {% assign app_namespace = '$app' %}
  {% assign server_url_field = shop.metafields[app_namespace]['serverUrl'] %}
  window.__BUNDLE_APP_URL__ = {% if server_url_field %}{{ server_url_field.value | json }}{% else %}null{% endif %};
</script>

{% # theme-check-disable RemoteAsset %}
<link
  rel="stylesheet"
  href="{{ shop.url }}/apps/product-bundles/api/design-settings/{{ shop.domain }}?bundleType=full_page"
  type="text/css"
>
{% # theme-check-enable RemoteAsset %}

<link rel="stylesheet" href="{{ 'bundle-widget-full-page.css' | asset_url }}">

<script>
  /* Move bundle widget into #MainContent so it renders between header and footer.
     App embed blocks inject at </body> (after footer) — this relocates it into the
     normal content flow. Runs synchronously to avoid layout shift. */
  (function() {
    var widget = document.getElementById('bundle-builder-app');
    var main = document.getElementById('MainContent');
    if (widget && main) {
      main.appendChild(widget);
    }
  })();
</script>

<script src="{{ 'bundle-widget-full-page-bundled.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Wolfpack: Product Bundles",
  "description": "WP | Full Page",
  "target": "body",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "This embed renders automatically on any page linked to a Wolfpack bundle. No per-page setup needed."
    }
  ]
}
{% endschema %}
